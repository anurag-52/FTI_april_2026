# Backend Environment Variables
# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://ioqxsvjavhytpuveknze.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# MSG91 WhatsApp
MSG91_API_KEY=your_msg91_api_key_here
MSG91_SENDER_ID=your_whatsapp_sender_number_here

# Brevo Email (free tier — 300 emails/day — https://brevo.com)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_NAME=Channel Breakout Signals
BREVO_SENDER_EMAIL=signals@yourdomain.com

# App
FRONTEND_URL=https://your-app.vercel.app
SECRET_KEY=generate_with_openssl_rand_hex_32
CRON_SECRET=generate_with_openssl_rand_hex_32

# Environment
ENVIRONMENT=production
